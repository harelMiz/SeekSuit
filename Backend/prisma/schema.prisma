// -------------------------------------
// Prisma Client Generator
// -------------------------------------
generator client {
  provider = "prisma-client-js"
}

// -------------------------------------
// Database Connection
// -------------------------------------
// NOTE: In Prisma 7, the datasource url is no longer defined here.
// - For CLI operations (migrations, generate): configured in prisma.config.ts
// - For runtime (PrismaClient): passed via @prisma/adapter-pg driver adapter in src/lib/prisma.ts
datasource db {
  provider = "postgresql"
}

// -------------------------------------
// Enums
// -------------------------------------

enum ProductType {
  JACKET
  PANTS
  SHIRT
  VEST
  SHOES
  TIE
  BOW_TIE
  BELT
}

enum ProductStatus {
  IN_STOCK
  OUT_OF_STOCK
}

// -------------------------------------
// Models
// -------------------------------------

model Product {
  id                 String           @id @default(uuid())
  name               String
  sku                String           @unique
  type               ProductType
  color              String?
  status             ProductStatus    @default(IN_STOCK)
  rawImageUrl        String?
  processedImageUrl  String?
  attributes         Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  processingJobs     ProcessingJob[]
}

// Tracks the async AI processing state for each product image
model ProcessingJob {
  id        String     @id @default(uuid())
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  status    JobStatus  @default(PENDING)
  errorMsg  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
