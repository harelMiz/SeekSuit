// -------------------------------------
// Prisma Client Generator
// -------------------------------------
generator client {
  provider = "prisma-client-js"
}

// -------------------------------------
// Database Connection
// -------------------------------------
datasource db {
  provider = "postgresql"
}

// -------------------------------------
// Enums
// -------------------------------------

enum ProductType {
  JACKET
  PANTS
  SHIRT
  VEST
  SHOES
  TIE
  BOW_TIE
  BELT
}

enum ProductStatus {
  IN_STOCK
  OUT_OF_STOCK
}

// -------------------------------------
// Models
// -------------------------------------

model Product {
  id                 String        @id @default(uuid())
  name               String
  sku                String        @unique
  type               ProductType
  color              String?
  status             ProductStatus @default(IN_STOCK)
  rawImageUrl        String?
  processedImageUrl  String?
  attributes         Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}
