// -------------------------------------
// Prisma Client Generator
// -------------------------------------
generator client {
  provider = "prisma-client-js"
}

// -------------------------------------
// Database Connection
// -------------------------------------
// NOTE: In Prisma 7, the datasource url is no longer defined here.
// - For CLI operations (migrations, generate): configured in prisma.config.ts
// - For runtime (PrismaClient): passed via @prisma/adapter-pg driver adapter in src/lib/prisma.ts
datasource db {
  provider = "postgresql"
}

// -------------------------------------
// Enums
// -------------------------------------

enum ProductType {
  JACKET
  PANTS
  SHIRT
  VEST
  SHOES
  TIE
  BOW_TIE
  BELT
}

enum ProductStatus {
  IN_STOCK
  OUT_OF_STOCK
}

// -------------------------------------
// Models
// -------------------------------------

model Product {
  id          String        @id @default(uuid())
  name        String
  sku         String        @unique
  type        ProductType
  color       String?
  status      ProductStatus @default(IN_STOCK)
  attributes  Json?
  images      ProductImage[]
  views       ProductView[]
  vtoJobs     VTOJob[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// Each product can have up to 5 images.
// isMain marks the primary display image.
// order controls display order (0 = first).
// productId is nullable — images can exist without a product while
// awaiting assignment in the bulk upload flow.
model ProductImage {
  id             String          @id @default(uuid())
  productId      String?
  product        Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawUrl         String?
  processedUrl   String?
  embedding      Unsupported("vector(512)")?
  dominantColor  String?
  isMain         Boolean         @default(false)
  isFrontView    Boolean         @default(false)
  isPublished    Boolean         @default(true)
  order          Int             @default(0)
  processingJobs ProcessingJob[]
  vtoJobs        VTOJob[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

// Tracks the async AI processing state for each product image
model ProcessingJob {
  id             String       @id @default(uuid())
  productImageId String
  image          ProductImage @relation(fields: [productImageId], references: [id], onDelete: Cascade)
  status         JobStatus    @default(PENDING)
  errorMsg       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum VTOStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum QueryType {
  TEXT
  IMAGE
  DETECT
}

enum ViewSource {
  BROWSE
  SEARCH_RESULT
  SIMILAR
}

// Records every fashion-relevant search (written only after TEXT_ABSOLUTE_FLOOR passes).
// ?skipLog=true on the request skips the write (for dev/admin testing).
model SearchLog {
  id            String    @id @default(uuid())
  query         String?
  queryType     QueryType
  resultCount   Int
  detectedColor String?
  createdAt     DateTime  @default(now())
}

// Tracks a virtual try-on generation job for a JACKET or VEST product image.
// RunPod runs FitDiT on all model photos and returns URLs in results JSON.
// results shape: [{ modelKey: string, url: string, selected: boolean }]
model VTOJob {
  id            String      @id @default(uuid())
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceImageId String
  sourceImage   ProductImage @relation(fields: [sourceImageId], references: [id], onDelete: Cascade)
  runpodJobId   String?
  status        VTOStatus   @default(PENDING)
  errorMsg      String?
  results       Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

// Records product page views from public users (skipped when admin is logged in).
model ProductView {
  id          String     @id @default(uuid())
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  source      ViewSource
  searchQuery String?
  createdAt   DateTime   @default(now())
}
