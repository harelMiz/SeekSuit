# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Both point to the same Supabase session-mode pooler (port 5432)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── AI Microservice ───────────────────────────────────────────────────────────
# URL the backend uses to reach the AI service container
AI_SERVICE_URL=http://localhost:8000

# ── LLM (Business Insight Agent) ─────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=<gemini-api-key>
GEMINI_MODEL=gemini-2.0-flash

# ── Virtual Try-On (RunPod serverless GPU) ────────────────────────────────────
RUNPOD_API_KEY=<runpod-api-key>
RUNPOD_ENDPOINT_ID=<runpod-endpoint-id>

# ── Contact Form ──────────────────────────────────────────────────────────────
CONTACT_EMAIL=<gmail-address>
CONTACT_APP_PASSWORD=<gmail-app-password>

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Dev / Debug ───────────────────────────────────────────────────────────────
# Set to "true" to skip analytics queries in development
SKIP_ANALYTICS=false
